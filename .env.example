VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Optional: live match scores (free tier at football-data.org)
VITE_FD_TOKEN=your-football-data-token-here

# Cloudflare Turnstile (bot protection on sign-up)
# Get your site key + secret key at https://dash.cloudflare.com → Turnstile
VITE_TURNSTILE_SITE_KEY=your-turnstile-site-key-here
# Set TURNSTILE_SECRET_KEY in Cloudflare Pages environment variables (NOT in .env — server-side only)
